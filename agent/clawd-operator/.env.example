# =============================================================================
# OpenClawd Operator – Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# Required variables are marked with [REQUIRED]
# Optional variables show their defaults.

# ---------------------------------------------------------------------------
# Solana / Jupiter Swap V2 – [REQUIRED for Solana Trading]
# ---------------------------------------------------------------------------
JUPITER_API_KEY=              # [REQUIRED] Get at https://developers.jup.ag/portal
SOLANA_PRIVATE_KEY=           # [REQUIRED] Base58-encoded Solana wallet private key
SOLANA_WALLET_PUBKEY=         # [OPTIONAL] Auto-derived from private key if omitted
DEFAULT_TOKEN_MINT=           # [REQUIRED] SPL token mint address to trade (e.g. 8cHzQHUS2s2h8TzCmfqPKYiM4dSt4roa3n7MyRLApump)

# ---------------------------------------------------------------------------
# Jupiter endpoints (defaults shown)
# ---------------------------------------------------------------------------
JUPITER_ENDPOINT=https://api.jup.ag
JUPITER_ULTRA_ENDPOINT=https://api.jup.ag/ultra
JUPITER_REFERRAL=             # Optional referral account for fee sharing

# ---------------------------------------------------------------------------
# Trading Strategy
# ---------------------------------------------------------------------------
TRADE_MODE=moderate           # conservative | moderate | aggressive | degen
DRY_RUN=true                  # Set false to execute real swaps
MAX_POSITION_SIZE_SOL=5.0     # Max SOL per position

# ---------------------------------------------------------------------------
# AI Agent API Keys – [OPTIONAL] for AI-powered trading decisions
# ---------------------------------------------------------------------------
# ANTHROPIC_API_KEY=          # For Claude adapter
# GEMINI_API_KEY=             # For Gemini adapter

# ---------------------------------------------------------------------------
# Web Dashboard
# ---------------------------------------------------------------------------
RALPH_WEB_PASSWORD=changeme   # Password for the monitoring dashboard (default: 69420)
RALPH_WEB_PORT=8080           # Dashboard port
