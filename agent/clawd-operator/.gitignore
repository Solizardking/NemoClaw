# ----------------------------------------------------------------------------
# Secrets — NEVER commit
# ----------------------------------------------------------------------------
# Env files (any name pattern, any depth)
.env
.env.*
!.env.example
!.env.template
!.env.sample
.env.local
# Private keys / certs / wallets
*.pem
*.key
*.p12
*.pfx
*.keystore
*.jks
*.asc
*.gpg
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
id_ecdsa
id_ecdsa.*
*.ppk
known_hosts
node_modules
# Wallet / keypair files
wallet.json
*-wallet.json
keypair.json
*-keypair.json
solana-keygen.json
phantom-export.json

# Service account / cloud credentials
service-account*.json
gcp-credentials*.json
google-credentials*.json
firebase-adminsdk*.json
aws-credentials
credentials.json
