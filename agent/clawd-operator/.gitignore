# ----------------------------------------------------------------------------
# Node / pnpm / bun
# ----------------------------------------------------------------------------
node_modules/
.pnpm-store/
.pnp.*
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# ----------------------------------------------------------------------------
# Python (clawd-operator etc.)
# ----------------------------------------------------------------------------
.venv/
venv/
env/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.Python
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ----------------------------------------------------------------------------
# Build / dist artifacts
# ----------------------------------------------------------------------------
dist/
build/
out/
.next/
.turbo/
.cache/
.parcel-cache/
.swc/
.tsbuildinfo
*.tsbuildinfo
coverage/
.nyc_output/

# ----------------------------------------------------------------------------
# Mobile / iOS / Android
# ----------------------------------------------------------------------------
# iOS
*.xcuserstate
xcuserdata/
DerivedData/
Pods/
*.mobileprovision
*.p8
*.ipa
*.dSYM.zip

# Android
.gradle/
local.properties
*.apk
*.aab
*.iml
captures/
google-services.json

# Expo / React Native
.expo/
.expo-shared/

# ----------------------------------------------------------------------------
# macOS / Windows / Linux junk
# ----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ----------------------------------------------------------------------------
# Editors / IDEs
# ----------------------------------------------------------------------------
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ----------------------------------------------------------------------------
# Logs / runtime / temp
# ----------------------------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.npm/
.eslintcache
.stylelintcache
*.pid
*.seed
*.pid.lock

# ----------------------------------------------------------------------------
# Test / generated data
# ----------------------------------------------------------------------------
generated/
tmp/
temp/
.tmp/

# ----------------------------------------------------------------------------
# Repo-specific
# ----------------------------------------------------------------------------
# Old/duplicate working folders — keep on disk but exclude from git
extensions copy/

# Local sessions / user state
.clawdbot/
sessions/
*.session

# Sentry / sourcemaps
.sentryclirc

# Claude Code / agent local state
.claude/
.cursor/

