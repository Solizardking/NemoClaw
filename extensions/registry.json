          "ASTER_API_SECRET",
          "ASTER_API_WALLET_PRIVATE_KEY"
        ],
        "required": []
      },
      "perps": {
        "supported": true,
        "venue": "aster",
        "quote": "USDT",
        "actions": [
          "open-long",
