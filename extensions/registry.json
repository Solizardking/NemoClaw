{
  "$schema": "./registry.schema.json",
  "formatVersion": 1,
  "status": "manifest-only",
  "updatedAt": "2026-07-02",
  "summary": "Compact NemoClaw extension catalog. Source-heavy Clawdbot extension drops are represented as declarative capability manifests without vendored runtime code, tests, generated output, lockfiles, or local credentials.",
  "conventions": {
    "execution": "Manifest-only entries describe extension capabilities and configuration boundaries; runtime adapters should live in first-party NemoClaw packages or be fetched from trusted upstreams at install time.",
    "credentialBoundary": "Do not place .env files, private keys, API key JSON files, lockfiles, nohup output, node_modules, or copied vendor SDK trees under extensions/.",
    "perps": "Perpetual futures capabilities are normalized under the trading.perps capability and the perps object."
  },
  "extensions": [
    {
      "id": "aster-dex",
      "path": "aster-dex",
      "name": "Aster DEX",
      "kind": "dex",
      "description": "Aster DEX market data, spot trading, price alerts, and perpetual futures actions.",
      "status": "manifest-only",
      "capabilities": [
        "trading.perps",
        "trading.spot",
        "market-data",
        "alerts"
      ],
      "tools": [
        "aster_open_long",
        "aster_open_short",
        "aster_close_position",
        "aster_spot_buy",
        "aster_spot_sell",
        "aster_cancel_order",
        "aster_cancel_all_orders",
        "aster_get_positions",
        "aster_get_open_orders",
        "aster_get_price",
        "aster_get_24hr_stats",
        "aster_get_chart",
        "aster_get_balance",
        "aster_analyze_market",
        "aster_create_alert",
        "aster_remove_alert",
        "aster_list_alerts"
      ],
      "config": {
        "namespace": "extensions.asterDex",
        "env": [
          "ASTER_API_KEY",
          "ASTER_API_SECRET",
