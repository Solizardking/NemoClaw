{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/NVIDIA/NemoClaw/extensions/registry.schema.json",
  "title": "NemoClaw Compact Extension Registry",
  "type": "object",
  "required": [
    "$schema",
    "formatVersion",
    "status",
    "updatedAt",
    "summary",
    "conventions",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "formatVersion": {
      "type": "integer",
      "minimum": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "manifest-only"
      ]
    },
    "updatedAt": {
      "type": "string"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "conventions": {
      "type": "object",
      "required": [
        "execution",
        "credentialBoundary",
        "perps"
      ],
      "additionalProperties": false,
      "properties": {
        "execution": {
          "type": "string"
        },
        "credentialBoundary": {
          "type": "string"
        },
        "perps": {
          "type": "string"
        }
      }
    },
    "extensions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/extension"
      }
    }
  },
  "$defs": {
    "extension": {
      "type": "object",
      "required": [
        "id",
        "path",
        "name",
        "kind",
        "description",
        "status",
        "capabilities",
        "config"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9 -]*[a-z0-9]$"
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "manifest-only",
            "alias"
          ]
        },
        "aliasOf": {
          "type": "string"
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "channels": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "tools": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "commands": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "config": {
          "$ref": "#/$defs/config"
        },
        "perps": {
          "$ref": "#/$defs/perps"
        }
      }
    },
    "config": {
      "type": "object",
      "required": [
        "namespace",
        "env",
        "secrets",
        "required"
      ],
      "additionalProperties": false,
      "properties": {
        "namespace": {
          "type": "string",
          "minLength": 1
        },
        "env": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "secrets": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "perps": {
      "type": "object",
      "required": [
        "supported"
      ],
      "additionalProperties": false,
      "properties": {
        "supported": {
          "type": "boolean"
        },
        "venue": {
          "type": "string"
        },
        "quote": {
          "type": "string"
        },
        "providers": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "actions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "orderTypes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "marginModes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "riskControls": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
