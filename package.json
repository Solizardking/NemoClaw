  "bin": {
    "nemoclawd": "bin/nemoclawd.js"
  },
  "scripts": {
    "test": "node --test test/*.test.js",
    "build:plugin": "tsc -p tsconfig.nemoclawd.json",
    "build:mcp": "npm --prefix nemo-clawd-mcp run build",
    "ai-training:check": "node scripts/verify-ai-training.js",
    "ai-training:model-kit:build": "npm --prefix ai-training/model-kit run build",
    "ai-training:local:plan": "python3 ai-training/scripts/run_local_clawd_stack.py --best-effort",
    "build": "npm run build:plugin && npm run build:mcp && npm run ai-training:check",
    "public:audit": "bash scripts/public-release-audit.sh",
    "tools:solana:readiness": "node --experimental-strip-types tools/e2e/solana-readiness.mts --no-network --json",
    "tools:solana:payments": "node --experimental-strip-types tools/e2e/solana-payments.mts --network devnet --recipient So11111111111111111111111111111111111111112 --tokens usdc,clawd --resource-url https://nemoclawd.local/api/paid --json",
    "tools:solana:keychain": "node --experimental-strip-types tools/e2e/solana-keychain.mts --backend memory --environment development --cluster local-validator --private-key-path ~/.config/solana/id.json --json",
    "pack:check": "npm pack --dry-run --cache /tmp/nemoclawd-npm-cache",
    "release:check": "npm run build && npm test && npm run public:audit && npm run pack:check",
    "publish:public": "npm publish --access public",
    "prepublishOnly": "npm run build && npm test"
  },
